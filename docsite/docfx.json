{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../ModSmith",
          "files": ["**/*.csproj"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern", "template"],
    "globalMetadata": {
      "_gitUrlPattern": "https://github.com/cpimhoff/ModSmith-Sts2/blob/main/ModSmith/{path}",
      "_appName": "ModSmith",
      "_appTitle": "ModSmith",
      "_appLogoPath": "images/icon.png",
      "_appFaviconPath": "images/favicon.png",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
